# ──────────────────────────────────────────────
# Hoppers Deployment Configuration
# Copy this file to .env and fill in values
# ──────────────────────────────────────────────

# Domain (used by Caddy for TLS and by services for URLs)
DOMAIN=hoppers.cc

# ──── Server ────
# Master secret for auth token generation (generate a random 64-char hex string)
# openssl rand -hex 32
HANDY_MASTER_SECRET=

# ──── PostgreSQL ────
POSTGRES_USER=hoppers
POSTGRES_PASSWORD=
POSTGRES_DB=hoppers

# ──── MinIO (S3) ────
MINIO_ROOT_USER=hoppers
MINIO_ROOT_PASSWORD=
S3_BUCKET=hoppers

# ──── Optional: Push Notifications ────
# EXPO_ACCESS_TOKEN=

# ──── Optional: Analytics ────
# POSTHOG_API_KEY=

# ──── Optional: Payments ────
# REVENUE_CAT_STRIPE=

# ──── Optional: GitHub Integration ────
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=https://api.hoppers.cc/v1/connect/github/callback
# GITHUB_WEBHOOK_SECRET=

# ──── Optional: Voice (ElevenLabs) ────
# ELEVENLABS_API_KEY=

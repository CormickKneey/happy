# ──────────────────────────────────────────────
# hoppers.cc → Redirect to app.hoppers.cc
# ──────────────────────────────────────────────
{$DOMAIN:hoppers.cc} {
	reverse_proxy webapp:80
}

# ──────────────────────────────────────────────
# api.hoppers.cc → API Server
# ──────────────────────────────────────────────
api.{$DOMAIN:hoppers.cc} {
	reverse_proxy server:3000

	# WebSocket support for Socket.io
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websocket server:3000
}

# ──────────────────────────────────────────────
# app.hoppers.cc → Web App
# ──────────────────────────────────────────────
app.{$DOMAIN:hoppers.cc} {
	reverse_proxy webapp:80
}

# ──────────────────────────────────────────────
# files.hoppers.cc → MinIO (public file access)
# ──────────────────────────────────────────────
files.{$DOMAIN:hoppers.cc} {
	reverse_proxy minio:9000
}

# ──────────────────────────────────────────────
# minio.hoppers.cc → MinIO Console (optional)
# ──────────────────────────────────────────────
minio.{$DOMAIN:hoppers.cc} {
	reverse_proxy minio:9001
}

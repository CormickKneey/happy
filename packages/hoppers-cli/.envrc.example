# Hoppers CLI Development Environment
#
# This file is for direnv users who want automatic environment switching
# when entering this directory.
#
# Setup:
#   1. Install direnv: https://direnv.net/
#   2. Copy this file: cp .envrc.example .envrc
#   3. Run: direnv allow
#
# The .envrc file is gitignored, so each developer can customize it.

export HOPPERS_HOME_DIR="$HOME/.hoppers-dev"
export HOPPERS_VARIANT="dev"
export HOPPERS_SERVER_URL="${HOPPERS_SERVER_URL:-https://api.cluster-fluster.com}"

echo "🔧 DEV environment activated (data: $HOPPERS_HOME_DIR)"
